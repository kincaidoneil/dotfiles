{
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": ["Read(**/.env)", "Read(**/.env.*)"]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Awaiting input\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high"
}
